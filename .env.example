# ── Server ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
API_BASE_URL=http://localhost:5000

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/news_platform
POSTGRES_DB=news_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT / Auth ────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=30d
COOKIE_SECRET=your-cookie-secret-change-this

# ── S3 / MinIO (Object Storage) ──────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=news-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_PUBLIC_URL=http://localhost:9000/news-media

# ── CORS (comma-separated allowed origins) ───────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="News Platform <noreply@yoursite.com>"

# ── Web Push (VAPID) ─────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@yoursite.com

# ── pgAdmin ──────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@news.com
PGADMIN_PASSWORD=admin123

# ── MinIO Console ────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Razorpay (Membership Payments) ──────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
